{
  "custom": {
    "projectName": "FlintiumProject"
  },
  "params": {},
  "props": {
    "defaultSize": {
      "height": 768,
      "width": 1200
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "title"
        },
        "position": {
          "x": 24,
          "y": 24,
          "width": 800,
          "height": 40
        },
        "props": {
          "text": "Project Generator",
          "style": {
            "fontSize": 24,
            "color": "#e6edf3",
            "fontWeight": "bold"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "hint"
        },
        "position": {
          "x": 24,
          "y": 70,
          "width": 1100,
          "height": 30
        },
        "props": {
          "text": "Pick instance presets and call flintium.tools.create_instance(path, udt) to materialize them.",
          "style": {
            "fontSize": 14,
            "color": "#8b949e",
            "fontWeight": "normal"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "instTable"
        },
        "position": {
          "x": 24,
          "y": 110,
          "width": 1150,
          "height": 580
        },
        "propConfig": {
          "props.data": {
            "binding": {
              "type": "expr",
              "config": {
                "expression": "runScript(\"flintium.tools.list_instances\", 0)"
              }
            }
          }
        },
        "props": {
          "selection": {
            "mode": "single"
          },
          "columns": [
            {
              "field": "id",
              "header": "Preset"
            },
            {
              "field": "label",
              "header": "Label"
            },
            {
              "field": "udt",
              "header": "UDT Type"
            },
            {
              "field": "path",
              "header": "Tag Path"
            }
          ]
        },
        "type": "ia.display.table"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "backgroundColor": "#0e1116"
      }
    },
    "type": "ia.container.coord"
  }
}