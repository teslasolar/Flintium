          "html": "<div style='font-size:13px;margin:6px 0'><b>tag.read(path)</b> \u2192 system.tag.readBlocking([path])[0]</div><div style='font-size:13px;margin:6px 0'><b>tag.write(path, value)</b> \u2192 system.tag.writeBlocking([path],[value])[0]</div><div style='font-size:13px;margin:6px 0'><b>tag.browse(path)</b> \u2192 system.tag.browse(path)</div><div style='font-size:13px;margin:6px 0'><b>tag.history(path)</b> \u2192 system.tag.queryTagHistory([path])</div><div style='font-size:13px;margin:6px 0'><b>udt.list()</b> \u2192 flintium.tools.list_udts()</div><div style='font-size:13px;margin:6px 0'><b>udt.detail(name)</b> \u2192 flintium.tools.udt_detail(name)</div><div style='font-size:13px;margin:6px 0'><b>udt.create(path, udt)</b> \u2192 flintium.tools.create_instance(path, udt)</div><div style='font-size:13px;margin:6px 0'><b>alarm.active()</b> \u2192 system.alarm.queryStatus()</div><div style='font-size:13px;margin:6px 0'><b>alarm.ack(path)</b> \u2192 system.alarm.acknowledge([path])</div><div style='font-size:13px;margin:6px 0'><b>gw.status()</b> \u2192 system.util.getGatewayAddress()</div><div style='font-size:13px;margin:6px 0'><b>db.query(sql)</b> \u2192 system.db.runQuery(sql, 'default')</div><div style='font-size:13px;margin:6px 0'><b>opc.browse(path)</b> \u2192 system.opc.browseServer(...)</div><div style='font-size:13px;margin:6px 0'><b>plc.status(name)</b> \u2192 flintium.tools.plc_status(name)</div><div style='font-size:13px;margin:6px 0'><b>troubleshoot(issue)</b> \u2192 flintium.tools.troubleshoot(issue)</div>",
